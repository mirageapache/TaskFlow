SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (Supabase)
# 留空時 Django 會自動 fallback 到本機 SQLite（僅供第一次啟動驗證前後端連通使用）
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# CORS（前端開發伺服器位址；TaskFlow 前端在 vite.config.ts 設為 5273）
CORS_ALLOWED_ORIGINS=http://localhost:5273

# Redis（Celery broker + result backend）
# 留空時 Celery 使用 memory:// 同步模式，不需外部 Redis 即可開發
REDIS_URL=

# Email（SMTP）
# EMAIL_HOST 留空時使用 console backend（開發用，不實際發信）
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=TaskFlow <noreply@taskflow.local>
# 是否啟用 Email 通知（預設：有設 EMAIL_HOST 時自動啟用）
EMAIL_NOTIFICATIONS_ENABLED=

# Sentry 錯誤監控
# 留空時不初始化 Sentry，避免本地 / CI 把錯誤送上去
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.2

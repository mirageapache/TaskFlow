SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (Supabase)
# 留空時 Django 會自動 fallback 到本機 SQLite（僅供第一次啟動驗證前後端連通使用）
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# CORS（前端開發伺服器位址；TaskFlow 前端在 vite.config.ts 設為 5273）
CORS_ALLOWED_ORIGINS=http://localhost:5273
